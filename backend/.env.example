# =============================================================================
# APPLICATION
# =============================================================================
APP_NAME=IzdajIznajmi
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_VERSION=dev

# For encryption key rotation: comma-separated list of old keys
APP_PREVIOUS_KEYS=

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

FRONTEND_URL=http://localhost:5173
FRONTEND_URLS=http://localhost:5173,http://127.0.0.1:5173
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:5173,127.0.0.1,127.0.0.1:5173

# =============================================================================
# DATABASE  (production uses port 5433)
# =============================================================================
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=izdaji
DB_USERNAME=postgres
DB_PASSWORD=postgres

# =============================================================================
# CACHE
# =============================================================================
CACHE_STORE=database
# CACHE_PREFIX=

# =============================================================================
# REDIS  (used for cache and/or queue when CACHE_STORE=redis / QUEUE_CONNECTION=redis)
# =============================================================================
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# =============================================================================
# QUEUE
# =============================================================================
QUEUE_CONNECTION=database
QUEUE_FAILED_DRIVER=database-uuids

# Failed-jobs alerting (via GET /api/v1/health/queue)
QUEUE_FAILED_JOBS_ALERT_ENABLED=false
QUEUE_FAILED_JOBS_ALERT_THRESHOLD=0
QUEUE_FAILED_JOBS_ALERT_COOLDOWN_SECONDS=300

# =============================================================================
# SESSION
# =============================================================================
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=localhost
SESSION_SECURE_COOKIE=false
SESSION_SAME_SITE=lax
SESSION_HTTP_ONLY=true

# =============================================================================
# LOGGING
# =============================================================================
LOG_CHANNEL=stack
# Comma-separated list of channels for the "stack" channel (e.g. single,structured)
LOG_STACK=single
LOG_LEVEL=debug
# Minimum level for the structured (security event) log channel — keep at 'info' so security events are never filtered out
LOG_STRUCTURED_LEVEL=info
# Retention in days for daily and structured log files
LOG_DAILY_DAYS=14
LOG_DEPRECATIONS_CHANNEL=null

# =============================================================================
# MONITORING — SENTRY
# =============================================================================
SENTRY_ENABLED=false
SENTRY_DSN=
SENTRY_RELEASE=${APP_VERSION}
SENTRY_ENVIRONMENT=${APP_ENV}

# =============================================================================
# BROADCASTING (Laravel Reverb)
# =============================================================================
BROADCAST_CONNECTION=reverb
REVERB_APP_ID=local
REVERB_APP_KEY=local
REVERB_APP_SECRET=local
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8080
REVERB_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# =============================================================================
# STORAGE
# =============================================================================
FILESYSTEM_DISK=local

# AWS S3 (for private/public disks in production)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# =============================================================================
# MAIL
# =============================================================================
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@example.com"
MAIL_FROM_NAME="${APP_NAME}"

VERIFICATION_CODE_TTL_MINUTES=10

# =============================================================================
# PAYMENTS — STRIPE
# =============================================================================
TRANSACTIONS_CURRENCY=EUR
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# =============================================================================
# PUSH NOTIFICATIONS (Web Push / VAPID)
# =============================================================================
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com
PUSH_NOTIFICATION_ICON=/vite.svg
PUSH_NOTIFICATION_BADGE=/vite.svg
# TTL in seconds for push notification delivery attempts
PUSH_NOTIFICATION_TTL=3600

# =============================================================================
# AUTHENTICATION & MFA
# =============================================================================
REQUIRE_MFA_FOR_ADMINS=false
MFA_ISSUER="${APP_NAME}"
MFA_RECOVERY_CODES=8
TRUSTED_DEVICE_TTL_DAYS=30
LOGIN_MAX_ATTEMPTS=10
LOGIN_LOCKOUT_MINUTES=15

# =============================================================================
# FRAUD DETECTION
# =============================================================================
FRAUD_SCORE_THRESHOLD=60
FRAUD_SCORE_WINDOW_DAYS=30

# Signal: failed MFA attempts
FRAUD_SIGNAL_FAILED_MFA_WEIGHT=8
FRAUD_SIGNAL_FAILED_MFA_THRESHOLD=3
FRAUD_SIGNAL_FAILED_MFA_WINDOW=10
FRAUD_SIGNAL_FAILED_MFA_COOLDOWN=30

# Signal: rapid chat messages
FRAUD_SIGNAL_RAPID_MESSAGES_WEIGHT=5
FRAUD_SIGNAL_RAPID_MESSAGES_THRESHOLD=12
FRAUD_SIGNAL_RAPID_MESSAGES_WINDOW=5

# Signal: rapid rental applications
FRAUD_SIGNAL_RAPID_APPLICATIONS_WEIGHT=10
FRAUD_SIGNAL_RAPID_APPLICATIONS_THRESHOLD=4
FRAUD_SIGNAL_RAPID_APPLICATIONS_WINDOW=30

# Signal: duplicate address attempt
FRAUD_SIGNAL_DUPLICATE_ADDRESS_WEIGHT=15
FRAUD_SIGNAL_DUPLICATE_ADDRESS_COOLDOWN=60

# Signal: session anomaly (logins from many different IPs/devices)
FRAUD_SIGNAL_SESSION_ANOMALY_WEIGHT=6
FRAUD_SIGNAL_SESSION_ANOMALY_THRESHOLD=3
FRAUD_SIGNAL_SESSION_ANOMALY_WINDOW_HOURS=24

# Signal: IP-level failed login threshold (structural log only — no user scope)
FRAUD_SIGNAL_FAILED_LOGIN_IP_THRESHOLD=20
FRAUD_SIGNAL_FAILED_LOGIN_IP_WINDOW=10

# Signal: KYC submitted by the same IP for multiple users
FRAUD_SIGNAL_KYC_MULTI_USER_IP_WEIGHT=20
FRAUD_SIGNAL_KYC_MULTI_USER_IP_THRESHOLD=2
FRAUD_SIGNAL_KYC_MULTI_USER_IP_WINDOW_HOURS=24
FRAUD_SIGNAL_KYC_MULTI_USER_IP_COOLDOWN=240

# Signal: rapid chat attachment uploads (rate limit hit)
FRAUD_SIGNAL_RAPID_UPLOADS_WEIGHT=5
FRAUD_SIGNAL_RAPID_UPLOADS_COOLDOWN=60

# =============================================================================
# SECURITY HEADERS
# =============================================================================
SECURITY_HEADERS_ENABLED=true
SECURITY_X_CONTENT_TYPE_OPTIONS=nosniff
SECURITY_X_FRAME_OPTIONS=SAMEORIGIN
SECURITY_REFERRER_POLICY=strict-origin-when-cross-origin
SECURITY_PERMISSIONS_POLICY="camera=(), microphone=(), geolocation=(self), payment=(), usb=(), interest-cohort=()"

# HSTS (enable in production only)
SECURITY_HSTS_ENABLED=false
SECURITY_HSTS_MAX_AGE=31536000
SECURITY_HSTS_INCLUDE_SUBDOMAINS=true
SECURITY_HSTS_PRELOAD=false
SECURITY_HSTS_PROD_ONLY=true

# CSP (enable and tune before enabling in production)
SECURITY_CSP_ENABLED=false
SECURITY_CSP_REPORT_ONLY=true
SECURITY_CSP_POLICY="default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self' data:; connect-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'self'; form-action 'self'"

# =============================================================================
# SEARCH
# =============================================================================
SEARCH_DRIVER=sql
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_KEY=
MEILISEARCH_INDEX=listings
SEARCH_MAX_RADIUS_KM=50
SEARCH_MAX_MAP_RESULTS=300
SEARCH_MAX_PER_PAGE=50

# =============================================================================
# GEOCODING
# =============================================================================
# Driver: "fake" (seeded random coords) or "nominatim" (OpenStreetMap)
GEOCODER_DRIVER=fake
GEOCODER_CACHE_TTL=1440
GEOCODER_NOMINATIM_URL=https://nominatim.openstreetmap.org/search
GEOCODER_NOMINATIM_EMAIL=
GEOCODER_NOMINATIM_COUNTRIES=
GEOCODER_NOMINATIM_RATE_LIMIT_MS=1200
GEOCODER_NOMINATIM_TIMEOUT=8

GEOCODER_SUGGEST_DRIVER=fake
GEOCODER_SUGGEST_CACHE_TTL=15

FAKE_GEOCODER_BASE_LAT=45
FAKE_GEOCODER_BASE_LNG=15
FAKE_GEOCODER_SPREAD_KM=120

# =============================================================================
# IMAGES
# =============================================================================
IMAGE_OPTIMIZE=true
IMAGE_MAX_WIDTH=1600
IMAGE_WEBP_QUALITY=80

# =============================================================================
# CHAT & ATTACHMENTS
# =============================================================================
CHAT_MESSAGES_PER_MINUTE=30
CHAT_ATTACHMENTS_PER_10_MINUTES=10
CHAT_ATTACHMENT_MAX_FILES=5
CHAT_ATTACHMENT_MAX_KB=10240
CHAT_ATTACHMENT_THUMB_WIDTH=480
CHAT_ATTACHMENT_WEBP_QUALITY=80
CHAT_TYPING_TTL=8
CHAT_PRESENCE_TTL=90

# =============================================================================
# KYC VERIFICATION
# =============================================================================
KYC_MAX_FILE_SIZE_KB=10240
KYC_DOCUMENT_RETENTION_DAYS=90
ENABLE_AV_SCAN=false
CLAMSCAN_BINARY=/usr/bin/clamscan
CLAMSCAN_TIMEOUT=60

# =============================================================================
# DATA RETENTION  (purge commands run daily 05:00–05:30)
# =============================================================================
DATA_RETENTION_CHAT_ATTACHMENTS_DAYS=365
DATA_RETENTION_AUDIT_LOGS_DAYS=730
DATA_RETENTION_NOTIFICATIONS_DAYS=90

# =============================================================================
# BACKUP VERIFICATION  (backup:verify runs daily at 06:00)
# =============================================================================
BACKUP_DIR=/var/backups/izdaji/postgres
BACKUP_STALENESS_ALERT_HOURS=26

# =============================================================================
# VITE — frontend variables bundled into the SPA build
# =============================================================================
VITE_APP_NAME="${APP_NAME}"
VITE_SEARCH_V2=true
