APP_ENV=testing
APP_KEY=base64:hzmQORK7KyHHXESZl48NawK9y5jejiKY6+8oVoLzHZQ=
APP_DEBUG=true
APP_URL=http://localhost
FRONTEND_URL=http://localhost
FRONTEND_URLS=http://localhost

# Sanctum stateful domains — must include localhost so test HTTP requests
# are treated as stateful (sessions get started for API routes).
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:5173,127.0.0.1,127.0.0.1:5173

DB_CONNECTION=sqlite
DB_DATABASE=:memory:

CACHE_STORE=array
CACHE_DRIVER=array
QUEUE_CONNECTION=sync

# Use the SQL search driver — Meilisearch is not available outside Docker
SEARCH_DRIVER=sql
